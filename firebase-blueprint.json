{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "AnalysisResult": {
      "title": "AnalysisResult",
      "description": "Result of a fake content analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who performed the analysis" },
        "content": { "type": "string", "description": "The text or URL analyzed" },
        "trustScore": { "type": "number", "description": "Score from 0 to 100" },
        "verdict": { "type": "string", "enum": ["Real", "Fake", "Suspicious", "Unverified"] },
        "analysisDetails": { "type": "string", "description": "Detailed explanation from AI" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "trustScore", "verdict", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/AnalysisResult" },
      "description": "User analysis history"
    }
  }
}
